# Default-ignore the existing workspace. This repository is used to distribute
# the OBE AI product workflow package and a minimal skill subset.
*

!.gitignore
!/README.md
!/START_HERE.md
!workflow/
!workflow/docs/
!workflow/docs/ai-product-workflow-sharing/
!workflow/docs/ai-product-workflow-sharing/**
!workflow/skills/
!workflow/skills/qa/
!workflow/skills/qa/**
workflow/skills/qa/**/__pycache__/
workflow/skills/qa/**/*.pyc
!workflow/skills/product/
!workflow/skills/product/README.md
!workflow/skills/product/web3-cex-product-team.md
!workflow/skills/product/pipelines.yaml
!workflow/skills/product/engineering-plan-review.md
!workflow/skills/product/web3-prd-figma-prompt.md
!workflow/skills/product/product-test-qa.md
!workflow/skills/product/web3-product-expert.md
!workflow/skills/product/doc-writer.md
!workflow/skills/product/market-researcher.md
!workflow/skills/product/data-analyst.md
!workflow/skills/product/cex-contract-testing-expert.md
!workflow/skills/product/ai-function-designer.md
!workflow/skills/product/OBE-product-ux-self-check.md
!workflow/skills/product/OBE-design-reference-playbook.md
!workflow/skills/product/web3-product-experience-expert/
!workflow/skills/product/web3-product-experience-expert/**
!scripts/
!scripts/sync-onebullex-android-qa-skill.sh
!scripts/sync-workflow-skills-to-cursor.sh
!scripts/sync-workflow-skills-to-codex.sh

.DS_Store
**/.DS_Store
.env
.env.*
!workflow/docs/ai-product-workflow-sharing/config/*.example
!workflow/docs/ai-product-workflow-sharing/config/*.example.toml
